# API (apps/api) — secret'lar yalnızca sunucu tarafında
PORT=3001
HOST=0.0.0.0

# YouTube Data API v3 — search.list (100 quota unit / çağrı)
# Yoksa adapter gated modda kalır; sunucu düşmez.
YOUTUBE_API_KEY=

# Bluesky Jetstream WebSocket (isteğe bağlı override)
BLUESKY_JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe?wantedCollections=app.bsky.feed.post

# Mobil (Expo) — fiziksel cihaz için LAN IP
# EXPO_PUBLIC_API_URL=http://192.168.1.50:3001
