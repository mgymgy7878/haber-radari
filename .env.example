# API (apps/api) — secret'lar yalnızca sunucu tarafında
PORT=3001
HOST=0.0.0.0

# YouTube Data API v3 — search.list (100 quota unit / çağrı)
# Yoksa adapter gated modda kalır; sunucu düşmez.
YOUTUBE_API_KEY=

# Bluesky Jetstream WebSocket (isteğe bağlı override)
BLUESKY_JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe?wantedCollections=app.bsky.feed.post

# Smart Digest (v0.6.0+) — backend-only, default kapalı
LLM_DIGEST_ENABLED=0
LLM_DIGEST_PROVIDER=mock
LLM_DIGEST_EXTERNAL_ENABLED=0
LLM_DIGEST_DAILY_LIMIT=20
LLM_DIGEST_PER_REQUEST_LIMIT=3
LLM_DIGEST_REQUIRE_CACHE=1
LLM_DIGEST_TIMEOUT_MS=8000
LLM_DIGEST_MODEL=
LLM_DIGEST_API_KEY=
# LLM_DIGEST_API_URL=https://api.openai.com/v1/chat/completions
# LLM_DIGEST_CACHE_DIR=apps/api/.cache/smart-digest
# LLM_DIGEST_BUDGET_DIR=apps/api/.cache/smart-digest-budget
# LLM_DIGEST_CACHE_TTL_MS=86400000
# LLM_DIGEST_PROMPT_VERSION=v0.6.1
# LLM_DIGEST_VERSION=v0.6.1

# Mobil (Expo) — fiziksel cihaz için LAN IP
# EXPO_PUBLIC_API_URL=http://192.168.1.50:3001
