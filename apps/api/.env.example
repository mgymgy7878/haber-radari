# Haber Radarı Smart Digest — local .env şablonu
# UYARI: Bu dosyayı kopyalayıp .env oluşturun; .env ASLA commit edilmez.
# Gerçek API key bu dosyaya veya repo'ya yazılmaz.

# Digest pipeline açık/kapalı (1=açık)
LLM_DIGEST_ENABLED=1

# mock = deterministik test; external = gerçek provider adapter (kapalıyken çağrılmaz)
LLM_DIGEST_PROVIDER=external

# Gerçek external LLM — DEFAULT KAPALI. Pilot anında operatör 1 yapar.
LLM_DIGEST_EXTERNAL_ENABLED=0

# Operatör onay kapısı — gerçek çağrı için OPERATOR_APPROVED_REAL_LLM_DIGEST=1 gerekir
LLM_DIGEST_REQUIRE_OPERATOR_APPROVAL=1

# Cache zorunlu — aynı input ikinci çağrıda provider tekrar çağrılmamalı
LLM_DIGEST_REQUIRE_CACHE=1

# Budget limitleri
LLM_DIGEST_DAILY_LIMIT=5
LLM_DIGEST_PER_REQUEST_LIMIT=1
LLM_DIGEST_TIMEOUT_MS=8000

# Provider config — local .env'de doldur, commit etme
LLM_DIGEST_MODEL=
LLM_DIGEST_API_KEY=

# Log güvenliği — default kapalı; prompt/response içeriği loglanmaz
LLM_DIGEST_LOG_PROMPTS=0
LLM_DIGEST_LOG_RESPONSES=0

# Gerçek external pilot anında: OPERATOR_APPROVED_REAL_LLM_DIGEST=1
# Onay cümlesi runbook'ta: docs/ops/v0.6.4-real-provider-pilot-runbook.md
