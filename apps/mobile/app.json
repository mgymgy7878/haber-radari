    "android": {
      "package": "com.haberradari.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a0e14"
      }
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
